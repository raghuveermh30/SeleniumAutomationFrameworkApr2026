<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Opencart App Test Regression Suite" thread-count="3"
       parallel="tests" verbose="4">

    <listeners>
        <listener class-name="com.aventstack.chaintest.plugins.ChainTestListener"/>
        <listener class-name="listeners.TestAllureListener" />
        <listener class-name="listeners.AnnotationTransformer" />
    </listeners>

    <test name="Login Page Test_chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="test.LoginPageTest"/>
        </classes>
    </test>

    <test name="Accounts Page Test_chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="test.HomePageTest"/>
        </classes>
    </test>

  <test name="Product Info Page Test">
         <parameter name="browser" value="chrome"/>
         <classes>
             <class name="test.ProductInfoPageTest"/>
         </classes>
     </test>

</suite>